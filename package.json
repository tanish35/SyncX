{
  "name": "syncx",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply syncx --local",
    "db:migrate:remote": "wrangler d1 migrations apply syncx --remote",
    "db:studio": "drizzle-kit studio",
    "test": "find src -name '*.test.ts' -exec node --import tsx --test {} +",
    "dev:setup": "cp -n .dev.vars.example .dev.vars 2>/dev/null; wrangler d1 migrations apply syncx --local",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "secrets": "echo 'Run: bunx wrangler secret put <NAME> for each in .dev.vars'"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.12",
    "@opennextjs/cloudflare": "^1.0.0",
    "@radix-ui/react-alert-dialog": "^1.1.18",
    "@radix-ui/react-avatar": "^1.2.1",
    "@radix-ui/react-checkbox": "^1.3.6",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-progress": "^1.1.11",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.2",
    "@radix-ui/react-tabs": "^1.1.16",
    "@tanstack/react-query": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.38.0",
    "jose": "^6.0.0",
    "lucide-react": "^1.23.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stremio-watched-bitfield": "^1.0.0",
    "tailwind-merge": "^3.6.0",
    "worker-mailer": "^1.2.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.5.2",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.0.0"
  }
}
